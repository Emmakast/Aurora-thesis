#!/bin/bash
#SBATCH --job-name=phys_eval_s3
#SBATCH --output=/home/ekasteleyn/aurora_thesis/thesis/logs/phys_eval_s3_%j.out
#SBATCH --error=/home/ekasteleyn/aurora_thesis/thesis/logs/phys_eval_s3_%j.err
#SBATCH --time=08:00:00
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=16
#SBATCH --mem=64G

# Activate the virtual environment
source /home/ekasteleyn/aurora_thesis/aurora_env/bin/activate

echo "Started Aurora S3 Physics Evaluation at $(date)"

# Run the physics evaluation (skipping the KE spectrum)
PYTHONUNBUFFERED=1 /home/ekasteleyn/aurora_thesis/aurora_env/bin/python /home/ekasteleyn/aurora_thesis/thesis/scripts/run_physics_evaluation_s3.py --year 2022 --no-spectrum --workers 16

echo "Finished at $(date)"
