#!/bin/bash
#SBATCH --job-name=fp16_compare
#SBATCH --output=/home/ekasteleyn/aurora_thesis/thesis/logs/fp16_compare_%j.out
#SBATCH --error=/home/ekasteleyn/aurora_thesis/thesis/logs/fp16_compare_%j.err
#SBATCH --time=01:00:00
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --gpus=1
#SBATCH --mem=64G
#SBATCH --partition=gpu_h100

source /home/ekasteleyn/aurora_thesis/aurora_env/bin/activate
echo "Started at $(date)"
nvidia-smi --query-gpu=name,memory.total --format=csv,noheader

PYTHONUNBUFFERED=1 /home/ekasteleyn/aurora_thesis/aurora_env/bin/python /home/ekasteleyn/aurora_thesis/thesis/scripts/plot_fp32_vs_fp16.py

echo "Finished at $(date)"
