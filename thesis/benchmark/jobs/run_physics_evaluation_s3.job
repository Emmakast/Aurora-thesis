#!/bin/bash
#SBATCH --job-name=physics_aurora_s3
#SBATCH --partition=rome
#SBATCH --time=24:00:00
#SBATCH --mem=128G
#SBATCH --cpus-per-task=32
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --output=slurm-%j.out
#SBATCH --error=slurm-%j.out

# ============================================================================
# Physics Evaluation for Aurora S3 Predictions
# ============================================================================
# Runs run_physics_evaluation_s3.py to compute physics metrics for Aurora
# predictions stored on S3.
#
# Usage:
#   sbatch run_physics_evaluation_s3.job
#   sbatch --export=ALL,YEAR=2022,MONTH=01 run_physics_evaluation_s3.job
#   sbatch --export=ALL,INIT_HOUR=12 run_physics_evaluation_s3.job
# ============================================================================

BASE_DIR="$HOME/aurora_thesis/thesis"
SCRIPT="$BASE_DIR/scripts/run_physics_evaluation_s3.py"
RESULTS_DIR="$BASE_DIR/results"
LOG_DIR="$BASE_DIR/logs"
PY="$HOME/aurora_thesis/aurora_env/bin/python"

# Default parameters (can be overridden via sbatch --export)
YEAR="${YEAR:-2022}"
MONTH="${MONTH:-}"
INIT_HOUR="${INIT_HOUR:-0}"
WORKERS="${WORKERS:-16}"

mkdir -p "$RESULTS_DIR" "$LOG_DIR"

# Build date arguments
if [ -n "$MONTH" ]; then
    DATE_ARG="--month ${YEAR}-${MONTH}"
    OUTPUT_SUFFIX="${YEAR}_${MONTH}"
else
    DATE_ARG="--year $YEAR"
    OUTPUT_SUFFIX="$YEAR"
fi

LOG_FILE="$LOG_DIR/physics_aurora_s3_${OUTPUT_SUFFIX}_$(date +%Y%m%d_%H%M%S).log"
OUTPUT_CSV="$RESULTS_DIR/physics_aurora_s3_${OUTPUT_SUFFIX}_init${INIT_HOUR}.csv"

{
    echo "========================================"
    echo "  PHYSICS EVALUATION: Aurora S3"
    echo "========================================"
    echo "Job ID:       ${SLURM_JOB_ID:-local}"
    echo "Date:         $(date)"
    echo "Hostname:     $(hostname)"
    echo "Year:         $YEAR"
    echo "Month:        ${MONTH:-all}"
    echo "Init hour:    ${INIT_HOUR}:00 UTC"
    echo "Workers:      $WORKERS"
    echo "Output:       $OUTPUT_CSV"
    echo "========================================"
    echo ""
} | tee "$LOG_FILE"

CMD="$PY $SCRIPT $DATE_ARG --init-hour $INIT_HOUR --workers $WORKERS --output $OUTPUT_CSV -v"

eval $CMD 2>&1 | tee -a "$LOG_FILE"

EXIT_CODE=${PIPESTATUS[0]}

{
    echo ""
    echo "========================================"
    if [ $EXIT_CODE -eq 0 ]; then
        echo "  COMPLETED SUCCESSFULLY"
        echo "  Output: $OUTPUT_CSV"
    else
        echo "  FAILED (exit code: $EXIT_CODE)"
    fi
    echo "========================================"
    echo "Finished: $(date)"
} | tee -a "$LOG_FILE"

exit $EXIT_CODE
