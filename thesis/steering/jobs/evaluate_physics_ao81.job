#!/bin/bash
#SBATCH --job-name=eval_phys_ao81
#SBATCH --output=/home/ekasteleyn/aurora_thesis/thesis/steering/logs/eval_phys_ao81_%j.out
#SBATCH --error=/home/ekasteleyn/aurora_thesis/thesis/steering/logs/eval_phys_ao81_%j.err
#SBATCH --time=2:00:00
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=16
#SBATCH --mem=128G
#SBATCH --partition=rome
#SBATCH --chdir=/home/ekasteleyn/aurora_thesis

# ── Environment ──────────────────────────────────────────────────────────────
module load 2023
module load PROJ/9.2.0-GCCcore-12.3.0
source /home/ekasteleyn/aurora_thesis/aurora_env/bin/activate

echo "========================================"
echo "  Evaluating Physical Consistency AO81  "
echo "========================================"

/home/ekasteleyn/aurora_thesis/aurora_env/bin/python thesis/benchmark/scripts/run_physics_evaluation_steered.py \
    --workers 16 \
    --output thesis/results/physics_aurora_ao81_steered.csv

echo "Job Finished: $(date)"
