#!/bin/bash
#SBATCH --job-name=patch_prefetch
#SBATCH --output=/home/ekasteleyn/aurora_thesis/thesis/steering/logs/patch_prefetch_%j.out
#SBATCH --error=/home/ekasteleyn/aurora_thesis/thesis/steering/logs/patch_prefetch_%j.err
#SBATCH --time=04:00:00
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=16
#SBATCH --mem=64G
#SBATCH --partition=rome
#SBATCH --chdir=/home/ekasteleyn/aurora_thesis/thesis/steering/scripts

# ── Environment ──────────────────────────────────────────────────────────────
module load 2023
module load PROJ/9.2.0-GCCcore-12.3.0
source /home/ekasteleyn/aurora_thesis/aurora_env/bin/activate

# ── Run ──────────────────────────────────────────────────────────────────────
echo "Prefetching HRES T0 Data for Spatio-Temporal Causal Tracing..."
