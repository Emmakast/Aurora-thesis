#!/bin/bash
#SBATCH --job-name=analyze_ao_attention
#SBATCH --output=/home/ekasteleyn/aurora_thesis/thesis/steering/logs/analyze_ao_%j.out
#SBATCH --error=/home/ekasteleyn/aurora_thesis/thesis/steering/logs/analyze_ao_%j.err
#SBATCH --time=4:00:00
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=16
#SBATCH --mem=64G
#SBATCH --partition=rome
#SBATCH --constraint=scratch-node
#SBATCH --chdir=/home/ekasteleyn/aurora_thesis/thesis/steering/scripts

# ── Environment ──────────────────────────────────────────────────────────────
module load 2023
module load PROJ/9.2.0-GCCcore-12.3.0
source /home/ekasteleyn/aurora_thesis/aurora_env/bin/activate

# ── Run ──────────────────────────────────────────────────────────────────────
echo "Starting Analysis..."
echo "Temporary directory (TMPDIR) is set to: $TMPDIR"

PYTHONUNBUFFERED=1 /home/ekasteleyn/aurora_thesis/aurora_env/bin/python prior_analysis/analyze_ao_attention.py

echo "Analysis COMPLETE: $(date)"
